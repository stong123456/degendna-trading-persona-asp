PORT=8788
PUBLIC_BASE_URL=https://your-domain.example

# Enable x402 payment protection for the paid scoring route.
X402_ENABLED=true
X402_NETWORK=eip155:196
X402_PRICE=$3.99
X402_PAY_TO=0xYourXLayerReceivingAddress

# OKX Developer Portal API credentials for the seller-side x402 facilitator.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com
OKX_SYNC_SETTLE=false
