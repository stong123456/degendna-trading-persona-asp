{
  "openapi": "3.1.0",
  "info": {
    "title": "DegenDNA Trading Persona ASP",
    "version": "degen-persona-code-v3-72q",
    "description": "Original DegenDNA.fun trading-behavior profiling service with quick, standard, and full paid report tiers. The model is not MBTI or Myers-Briggs content and does not provide investment advice."
  },
  "servers": [
    {
      "url": "https://degendna-trading-persona-asp-production.up.railway.app"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Check service health and payment configuration.",
        "responses": {
          "200": {
            "description": "Service status"
          }
        }
      }
    },
    "/api/asp/trading-persona": {
      "get": {
        "summary": "Get questionnaire metadata for quick, standard, or full mode.",
        "parameters": [
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["quick", "standard", "full"],
              "default": "quick"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["zh", "en"],
              "default": "zh"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Questionnaire payload"
          }
        }
      },
      "post": {
        "summary": "Free catalog endpoint. It does not return a persona report.",
        "responses": {
          "200": {
            "description": "Catalog and paid route options"
          }
        }
      }
    },
    "/api/asp/trading-persona/preview": {
      "post": {
        "summary": "Free preview catalog endpoint for report tiers and paid routes.",
        "responses": {
          "200": {
            "description": "Catalog and paid route options"
          }
        }
      }
    },
    "/api/asp/trading-persona/score/quick": {
      "post": {
        "summary": "Paid 12-question quick-card report. Suggested fee: 0.10 USDT.",
        "parameters": [
          { "$ref": "#/components/parameters/Lang" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/ScoreRequest"
        },
        "responses": {
          "200": {
            "description": "Quick persona card"
          },
          "400": {
            "description": "Invalid or insufficient answers"
          },
          "402": {
            "description": "Payment required when x402 protection is enabled"
          }
        }
      }
    },
    "/api/asp/trading-persona/score/standard": {
      "post": {
        "summary": "Paid 24-question standard report. Suggested fee: 1.99 USDT.",
        "parameters": [
          { "$ref": "#/components/parameters/Lang" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/ScoreRequest"
        },
        "responses": {
          "200": {
            "description": "Standard report"
          },
          "400": {
            "description": "Invalid or insufficient answers"
          },
          "402": {
            "description": "Payment required when x402 protection is enabled"
          }
        }
      }
    },
    "/api/asp/trading-persona/score/full": {
      "post": {
        "summary": "Paid 72-question full playbook report. Suggested fee: 3.99 USDT.",
        "parameters": [
          { "$ref": "#/components/parameters/Lang" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/ScoreRequest"
        },
        "responses": {
          "200": {
            "description": "Full report"
          },
          "400": {
            "description": "Invalid or insufficient answers"
          },
          "402": {
            "description": "Payment required when x402 protection is enabled"
          }
        }
      }
    },
    "/api/asp/trading-persona/score": {
      "post": {
        "summary": "Legacy paid full-report endpoint. Prefer /score/full for new listings.",
        "parameters": [
          { "$ref": "#/components/parameters/Lang" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/ScoreRequest"
        },
        "responses": {
          "200": {
            "description": "Full report"
          },
          "402": {
            "description": "Payment required when x402 protection is enabled"
          }
        }
      }
    },
    "/report/demo": {
      "get": {
        "summary": "Render a visual demo report page using sample answers.",
        "parameters": [
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["quick", "standard", "full"],
              "default": "quick"
            }
          },
          { "$ref": "#/components/parameters/Lang" }
        ],
        "responses": {
          "200": {
            "description": "HTML visual demo report"
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "summary": "MCP-compatible JSON-RPC endpoint exposing questionnaire, calibration preview, and natural-language profile preview tools.",
        "responses": {
          "200": {
            "description": "JSON-RPC response"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Lang": {
        "name": "lang",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": ["zh", "en"],
          "default": "zh"
        }
      }
    },
    "requestBodies": {
      "ScoreRequest": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "answers": {
                  "description": "Submit every answer required by the selected tier. Arrays are mapped to the returned question order. Objects must use the questionnaire's canonical degenPersona:<questionIndex> keys. Scores are normalized per dimension to the complete 72-question scale.",
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "type": "number",
                        "minimum": -2,
                        "maximum": 2
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "type": "number",
                        "minimum": -2,
                        "maximum": 2
                      }
                    }
                  ]
                }
              },
              "required": ["answers"]
            }
          }
        }
      }
    }
  }
}
